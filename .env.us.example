# Longbridge OpenAPI credentials
LONGBRIDGE_APP_KEY=your_app_key
LONGBRIDGE_APP_SECRET=your_app_secret
LONGBRIDGE_ACCESS_TOKEN=your_access_token

# Notifier
NOTIFIER_CHANNEL=feishu
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your_webhook_token
ENABLE_TELEGRAM=true
TELEGRAM_BOT_TOKEN=your_bot_token
TELEGRAM_CHAT_ID=your_chat_id

# US-only watchlist
WATCHLIST=US.SPY,US.QQQ,US.MU,US.SNDK,US.GLW,US.IREN,US.TSLA,US.MSFT,US.NVDA

# Timeframes
EXECUTION_TIMEFRAME=15m
TREND_TIMEFRAME=1h
CONFIRM_TIMEFRAMES=5m,1m

# Strategy thresholds
RSI_RECOVERY_THRESHOLD=48
EXIT_RSI_THRESHOLD=42
BREAKOUT_LOOKBACK_BARS=20
SWING_LOOKBACK_BARS=20
VOLUME_RATIO_MIN=1.2
RESISTANCE_BUFFER_PCT=0.008
MAX_EXTENSION_PCT=0.03
ENTRY_ZONE_PCT=0.004

# Filters
ENABLE_ATR_FILTER=true
ATR_PERIOD=14
ATR_MIN_PCT=0.003
ATR_MAX_PCT=0.05
ENABLE_RELATIVE_STRENGTH_FILTER=true
RELATIVE_STRENGTH_BENCHMARK=US.SPY
RELATIVE_STRENGTH_LOOKBACK_BARS=20
RELATIVE_STRENGTH_MIN_EXCESS_RETURN=0.0
ENABLE_BREAKOUT_RETEST_FILTER=true
BREAKOUT_RETEST_TOLERANCE_PCT=0.004

# Alert controls
ALERT_COOLDOWN_MINUTES=30
DUPLICATE_PRICE_TOLERANCE_PCT=0.003
ALERT_MIN_PRIORITY_TIER=B
TRADING_HOURS_ONLY=true
US_MARKET_TZ=America/New_York
MARKET_OPEN_HHMM=09:30
MARKET_CLOSE_HHMM=16:00
POLL_INTERVAL_SECONDS=60

# Reports
ENABLE_DAILY_REPORT=true
DAILY_REPORT_SEND_HHMM=16:10
DAILY_REPORT_TOP_N=5
ENABLE_SYMBOL_MERGE_ALERTS=true
SYMBOL_MERGE_WINDOW_MINUTES=20
ENABLE_WEEKLY_REPORT=true
WEEKLY_REPORT_SEND_WEEKDAY=4
WEEKLY_REPORT_SEND_HHMM=16:20
WEEKLY_REPORT_TOP_N=8

# LLM
ENABLE_LLM_ANALYSIS=false
LLM_PROVIDER=openai
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=gpt-4o-mini
LLM_TIMEOUT_SECONDS=15
LLM_SIGNAL_TYPES=long_setup,breakout_candidate

# Run mode
DRY_RUN=false

# Storage
SQLITE_PATH=data/signals.db
LOG_LEVEL=INFO
